---
import Layout from "../../../components/layouts/Layout.astro";
import SEO from "../../../components/layouts/utils/SEO.astro";

import { client } from "../../../assets/scripts/utils/api/sanityClient";
import { getAllProjects } from "../../../assets/scripts/utils/api/api";
//
import Heading from '../../../components/molecules/Heading';
import ProjectList from '../../../components/molecules/ProjectList'

let allProjects = await client.fetch(getAllProjects());
allProjects = allProjects.filter(el => el.category === 'design')
import OG_IMAGE from "@/assets/images/layout/og/OG_IMAGE_DESIGN_PROJECTS.jpg";
---

<SEO lang="en" title="Design — Branding, UI/UX & Visual Identity | Donaël Walter" description="Browse brand identity, UI/UX design, and visual projects by Donaël Walter. From logos to complete design systems." ogImage={OG_IMAGE.src} canonical="https://donaelwalter.com/projects/design" jsonLd={{"@context":"https://schema.org","@graph":[{"@type":"Person","@id":"https://donaelwalter.com/#person","name":"Donaël Walter","url":"https://donaelwalter.com","jobTitle":["Brand Designer","Creative Developer","Front-End Engineer"],"knowsAbout":["Branding","UX Design","UI Design","Front-End Development","Web Development"]},{"@type":"WebSite","@id":"https://donaelwalter.com/#website","url":"https://donaelwalter.com","name":"Donaël Walter","description":"Brand designer and creative developer — blending branding, UX, UI, and front-end development into polished web experiences.","publisher":{"@id":"https://donaelwalter.com/#person"}},{"@type":"CollectionPage","@id":"https://donaelwalter.com/projects/design","name":"Design — Branding, UI/UX & Visual Identity","isPartOf":{"@id":"https://donaelwalter.com/#website"}}]}}>
	<Layout>
		<Heading client:load>
            <h1>Design</h1>
            <p>Graphic Design, UI /UX, 3D design and more ...</p>
        </Heading>
        <ProjectList projects={allProjects} client:load/>
	</Layout>
</SEO>


