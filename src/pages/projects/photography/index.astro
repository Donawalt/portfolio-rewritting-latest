---
import Layout from "../../../components/layouts/Layout.astro";
import SEO from "../../../components/layouts/utils/SEO.astro";

import { client } from "../../../assets/scripts/utils/api/sanityClient";
import { getAllProjects } from "../../../assets/scripts/utils/api/api";
//
import Heading from '../../../components/molecules/Heading';
import ProjectList from '../../../components/molecules/ProjectList'

let allProjects = await client.fetch(getAllProjects());
allProjects = allProjects.filter(el => el.category === 'photography')

import OG_IMAGE from "@/assets/images/layout/og/OG_IMAGE_PHOTOGRAPHY_PROJECTS.jpg";
---

<SEO lang="en" title="Photography — Visual Stories & Portfolios | Donaël Walter" description="Browse Donaël Walter's photography — portraits, landscapes, and creative visual stories." ogImage={OG_IMAGE.src} canonical="https://donaelwalter.com/projects/photography" jsonLd={{"@context":"https://schema.org","@graph":[{"@type":"Person","@id":"https://donaelwalter.com/#person","name":"Donaël Walter","url":"https://donaelwalter.com","jobTitle":["Brand Designer","Creative Developer","Front-End Engineer"],"knowsAbout":["Branding","UX Design","UI Design","Front-End Development","Web Development"]},{"@type":"WebSite","@id":"https://donaelwalter.com/#website","url":"https://donaelwalter.com","name":"Donaël Walter","description":"Brand designer and creative developer — blending branding, UX, UI, and front-end development into polished web experiences.","publisher":{"@id":"https://donaelwalter.com/#person"}},{"@type":"CollectionPage","@id":"https://donaelwalter.com/projects/photography","name":"Photography — Visual Stories & Portfolios","isPartOf":{"@id":"https://donaelwalter.com/#website"}}]}}>
	<Layout>
		<Heading client:load>
            <h1>Photography</h1>
            <p>An overview of my photographic journey</p>
        </Heading>
        <ProjectList projects={allProjects} client:load/>
	</Layout>
</SEO>


