---
import Layout from "../../../components/layouts/Layout.astro";
import SEO from "../../../components/layouts/utils/SEO.astro";

import { client } from "../../../assets/scripts/utils/api/sanityClient";
import { getAllProjects } from "../../../assets/scripts/utils/api/api";
//
import Heading from '../../../components/molecules/Heading';
import ProjectList from '../../../components/molecules/ProjectList'

let allProjects = await client.fetch(getAllProjects());
allProjects = allProjects.filter(el => el.category === 'development')
import OG_IMAGE from "@/assets/images/layout/og/OG_IMAGE_DEVELOPMENT_PROJECTS.jpg";
---

<SEO lang="en" title="Development — Front-End & Web Dev | Donaël Walter" description="Browse front-end development, web apps, and interactive experiences built by Donaël Walter — from concept to deployment." ogImage={OG_IMAGE.src} canonical="https://donaelwalter.com/projects/development" jsonLd={{"@context":"https://schema.org","@graph":[{"@type":"Person","@id":"https://donaelwalter.com/#person","name":"Donaël Walter","url":"https://donaelwalter.com","jobTitle":["Brand Designer","Creative Developer","Front-End Engineer"],"knowsAbout":["Branding","UX Design","UI Design","Front-End Development","Web Development"]},{"@type":"WebSite","@id":"https://donaelwalter.com/#website","url":"https://donaelwalter.com","name":"Donaël Walter","description":"Brand designer and creative developer — blending branding, UX, UI, and front-end development into polished web experiences.","publisher":{"@id":"https://donaelwalter.com/#person"}},{"@type":"CollectionPage","@id":"https://donaelwalter.com/projects/development","name":"Development — Front-End & Web Dev","isPartOf":{"@id":"https://donaelwalter.com/#website"}}]}}>
	<Layout>
		<Heading client:load>
            <h1>Development</h1>
            <p>Web development projects selection</p>
        </Heading>
        <ProjectList projects={allProjects} client:load/>
	</Layout>
</SEO>


