---
import Layout from "../components/layouts/Layout.astro";
import SEO from "../components/layouts/utils/SEO.astro";
import ProjectList from '../components/molecules/ProjectList';
import Button from '../components/atoms/Button/index';

import HomeStyles from "./index.module.scss";

import OG_IMAGE from "@/assets/images/layout/og/OG_IMAGE_HOME.jpg";

import { client } from "../assets/scripts/utils/api/sanityClient";
import { getAllProjects } from "../assets/scripts/utils/api/api";

const allProjects = await client.fetch(getAllProjects());

const mainProjects = allProjects
  .filter(p => p.category === 'design' || p.category === 'development')
  .slice(0, 9);

---

<SEO lang="en" title="Donaël Walter — Design Engineer & Creative Developer | Design, UI/UX, Front-End" description="I help startups, agencies, and premium brands turn goals into polished web experiences — blending branding, UX, UI, and development in one workflow." ogImage={OG_IMAGE.src} canonical="https://donaelwalter.com" jsonLd={{"@context":"https://schema.org","@graph":[{"@type":"Person","@id":"https://donaelwalter.com/#person","name":"Donaël Walter","url":"https://donaelwalter.com","jobTitle":["Brand Designer","Creative Developer","Front-End Engineer"],"knowsAbout":["Branding","UX Design","UI Design","Front-End Development","Web Development"]},{"@type":"WebSite","@id":"https://donaelwalter.com/#website","url":"https://donaelwalter.com","name":"Donaël Walter","description":"Brand designer and creative developer — blending branding, UX, UI, and front-end development into polished web experiences.","publisher":{"@id":"https://donaelwalter.com/#person"}}]}}>
	<Layout>
		<main class={HomeStyles.home_page}>
			<header class={HomeStyles.hero} data-hero>
				<span class={HomeStyles.label}>Freelance</span>
				<div class={HomeStyles.hero_title}>
					<h1>
						<span class={HomeStyles.line_1}>Creative</span>
						<span class={HomeStyles.line_2}>Developer</span>
					</h1>
				</div>
				<p class={HomeStyles.description}>
					I turn product and brand goals into premium web experiences.
					Bridging branding, design, and code in one workflow — from visual identity to polished front-end development.
				</p>
				<div class={HomeStyles.cta_group}>
					<Button type="link" href="/projects">View Projects</Button>
					<Button type="link" href="mailto:contact@donaelwalter.com">Get in Touch</Button>
				</div>
			</header>

			<section>
				<div class={HomeStyles.section_title}>
					<h2>Selected Work</h2>
					<div class={HomeStyles.line}></div>
				</div>
				<ProjectList client:load projects={mainProjects} />
			</section>
		</main>
	</Layout>
</SEO>




