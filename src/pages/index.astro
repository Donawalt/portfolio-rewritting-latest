---
import Layout from "../components/layouts/Layout.astro";
import SEO from "../components/layouts/utils/SEO.astro";
import ProjectList from '../components/molecules/ProjectList';
import Button from '../components/atoms/Button/index';
import Steps from '../components/organisms/Section/slices/Steps';
import HomeStyles from "./index.module.scss";

import OG_IMAGE from "@/assets/images/layout/og/OG_IMAGE_HOME.jpg";

import { client } from "../assets/scripts/utils/api/sanityClient";
import { getAllProjects } from "../assets/scripts/utils/api/api";

const allProjects = await client.fetch(getAllProjects());

const mainProjects = allProjects
  .filter(p => p.category === 'design' || p.category === 'development')
  .slice(0, 10);

const photoProjects = allProjects
  .filter(p => p.category === 'photography')
  .slice(0, 3);

const whyCards = [
  {
    title: "Multidisciplinary",
    description: "Brand design, UI/UX, 3D, motion, and development. I bring multiple perspectives to solve problems others might miss."
  },
  {
    title: "Unique Vision",
    description: "Through diverse skills and experience, I offer tailor-made solutions that make brands unforgettable."
  },
  {
    title: "Full-Stack Builder",
    description: "I don't just design — I build. Custom code, animations, and interactions that bring ideas to life."
  }
];
---

<SEO lang="en" title="Donaël Walter Portfolio | Creative Development, Design, Photography" description="I am Donaël - a skilled brand designer, web developer, and photographer. With my expertise in visual design and technical proficiency, I offer comprehensive solutions that are both functional and aesthetically pleasing." ogImage={OG_IMAGE.src}>
	<Layout>
		<main class={HomeStyles.home_page}>
			<header class={HomeStyles.hero} data-hero>
				<span class={HomeStyles.label}>Freelance</span>
				<div class={HomeStyles.hero_title}>
					<h1>
						<span class={HomeStyles.line_1}>Creative</span>
						<span class={HomeStyles.line_2}>Developer</span>
						<span class={HomeStyles.line_3}>& Designer</span>
					</h1>
				</div>
				<p class={HomeStyles.description}>
					I help brands shine through design, development, and photography.
					Crafting memorable digital experiences that are both functional and beautiful.
				</p>
				<div class={HomeStyles.cta_group}>
					<Button type="link" href="/projects">View Projects</Button>
					<Button type="link" href="https://cal.com/donael-walter/15min" target="_blank">Book a Call</Button>
				</div>
			</header>

			<section>
				<div class={HomeStyles.section_title}>
					<h2>Selected Work</h2>
					<div class={HomeStyles.line}></div>
				</div>
				<ProjectList client:load projects={mainProjects} />
			</section>
		</main>
	</Layout>
</SEO>




