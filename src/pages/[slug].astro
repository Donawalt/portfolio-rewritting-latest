---
import type { GetStaticPaths } from "astro";
import Layout from "../components/layouts/Layout.astro";
import SEO from "../components/layouts/utils/SEO.astro";
import Landing from "../components/templates/Landing.astro";
import { client } from "../assets/scripts/utils/api/sanityClient";
import { getAllLandings } from "../assets/scripts/utils/api/api";
import { urlImageBuilder } from "@/assets/scripts/utils/api/urlBuilder";

export const getStaticPaths = (async () => {
    const allLandings = await client.fetch(getAllLandings());

    return allLandings.map((page, index)=>{
        return {
            params: {slug: page.seoSlug.current},
            props: {page}
        }
    });
}) satisfies GetStaticPaths;

const {slug, type} = Astro.params;
const {page}:{page: any} = Astro.props;

const canonicalUrl = `https://donaelwalter.com/${page?.seoSlug?.current}`;
const webPageJsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://donaelwalter.com/#person",
      "name": "Donaël Walter",
      "url": "https://donaelwalter.com",
      "jobTitle": ["Brand Designer", "Creative Developer", "Front-End Engineer"],
      "knowsAbout": ["Branding", "UX Design", "UI Design", "Front-End Development", "Web Development"]
    },
    {
      "@type": "WebSite",
      "@id": "https://donaelwalter.com/#website",
      "url": "https://donaelwalter.com",
      "name": "Donaël Walter",
      "description": "Brand designer and creative developer — blending branding, UX, UI, and front-end development into polished web experiences.",
      "publisher": { "@id": "https://donaelwalter.com/#person" }
    },
    {
      "@type": "WebPage",
      "@id": canonicalUrl,
      "name": page.seoTitle,
      "description": page.seoDescription,
      "isPartOf": { "@id": "https://donaelwalter.com/#website" }
    }
  ]
};
---

<SEO lang="en" title={page.seoTitle + " | Donaël Walter"} description={page.seoDescription} ogDescription={page.seoDescription} keywords={page?.seoKeywords} ogImage={page?.seoImage && urlImageBuilder(page?.seoImage.asset._ref)} canonical={canonicalUrl} jsonLd={webPageJsonLd}>
	<Layout>
		<Landing type={page.category} title={page.name} subTitle={page.subtitle} cover={page.cover} content={page.content} comitments={page.comitments}/>
	</Layout>
</SEO>

<script define:vars={{page}}>
    console.log(page);
</script>